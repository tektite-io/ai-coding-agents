{
  "$schema": "https://opencode.ai/config.json",
  "model": "google-vertex/gemini-3.1-pro-preview",
  "small_model": "google-vertex/gemini-3.5-flash",
  "enabled_providers": ["google-vertex", "openrouter", "anthropic", "calculon"],
  "provider": {
    "google-vertex": {
      "models": {
        "gemini-3.5-flash": {},
        "gemini-3.1-pro-preview": {},
      },
      "options": {
        "project": "{env:VERTEXAI_PROJECT_ID}",
        "location": "{env:VERTEXAI_REGION}",
      },
    },
    "anthropic": {
      "models": {
        "claude-opus-4-6": {},
        "claude-sonnet-4-6": {},
        "claude-haiku-4-5": {},
      },
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}",
      },
    },
    "calculon": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "calculon",
      "options": {
        "baseURL": "http://calculon.local:8000/v1",
        "apiKey": "{env:OMLX_API_KEY}",
      },
      "models": {
        "Qwen3.5-9B-MLX-4bit": {
          "name": "Qwen3.5-9B-MLX-4bit",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "gemma-4-e4b-it-8bit": {
          "name": "gemma-4-e4b-it-8bit",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
      },
    },
  },
  "default_agent": "plan",
  "autoupdate": true,
  "instructions": ["~/.ai-agents/rules/*.md"],
  "share": "disabled",
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-websearch",
    "opencode-cost-guard",
    "file:///Users/jjmartres/.config/opencode/plugins/codeisland.js",
  ],
  "mcp": {
    "smartplaylist": {
      "type": "remote",
      "url": "http://personal.local:8000/mcp",
      "enabled": true,
    },
  },
}
